# Window Rules for workspace assignments

# Email client -> workspace 1
windowrule = workspace 1, match:class org.mozilla.Thunderbird

# Google Calendar PWA -> workspace 1
windowrule = workspace 1, match:class chrome-kjbdgfilnfhdoflbpgamdcdgpehopbep-Default
windowrule = workspace 1, match:class chrome-calendar.google.com__-Default

# Terminal emulators -> workspace 2
windowrule = workspace 2, match:class com.mitchellh.ghostty

# Browser -> workspace 3
windowrule = workspace 3 silent, match:class chromium

# Helium browser -> workspace 4
windowrule = workspace 4 silent, match:class helium
windowrule = workspace 4 silent, match:class Helium

# Obsidian -> workspace 5
windowrule = workspace 5 silent, match:class obsidian

# Basecamp PWA -> workspace 5
windowrule = workspace 5 silent, match:class chrome-ijbgeooaanmapjndajkllhcjbjpmnhhp-Default

# Notion PWA -> workspace 6
windowrule = workspace 6, match:class chrome-kbkccnkbejohggfkineepggmmnbdekdh-Default

# YouTube PWA -> workspace 6
windowrule = workspace 6, match:class chrome-youtube.com__-Default

# Steam -> workspace 6
windowrule = workspace 6, match:class steam
windowrule = workspace 6, match:class Steam

# AI Scheduler -> workspace 6
windowrule = workspace 6, match:class dev.ai-scheduler.desktop
windowrule = workspace 6, match:class ai-scheduler

# Cursor app -> workspace 7
windowrule = workspace 7, match:class Cursor
windowrule = workspace 7, match:class cursor

# Codex PWA -> workspace 7
windowrule = workspace 7, match:class chrome-bnppglmjfpalnebkpjnhfflioohnlplp-Default
windowrule = workspace 7, match:class crx_bnppglmjfpalnebkpjnhfflioohnlplp

# T3 Code -> workspace 7
windowrule = workspace 8, match:class t3code

# AI web apps (PWAs) -> workspace 8
# ChatGPT PWA
windowrule = workspace 8, match:class chrome-chatgpt.com__-Default

# Claude PWA
windowrule = workspace 8, match:class chrome-claude.ai__-Default

# WhatsApp -> workspace 9
windowrule = workspace 9, match:class chrome-web.whatsapp.com__-Default

# Slack -> workspace 9
windowrule = workspace 9, match:class Slack
windowrule = workspace 9, match:class slack

# Apple Music -> workspace 10
windowrule = workspace 10 silent, match:class chrome-blgdilankhbcpipclgpdndahbehalgkh-Default
windowrule = workspace 10 silent, match:class crx_blgdilankhbcpipclgpdndahbehalgkh

# iCloud Reminders -> workspace 10
windowrule = workspace 10 silent, match:class chrome-cpdadiipndabhlkmcgbkbllgcjmpjggd-Default
windowrule = workspace 10 silent, match:class chrome-www.icloud.com__reminders-Default
