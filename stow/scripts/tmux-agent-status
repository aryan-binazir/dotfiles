#!/usr/bin/env bash

# Detect busy AI panes and drive their shared tmux spinner.
# Supports title-based agents (Codex) and TUI status lines (Cursor, Pi, Claude).

mode=${1:-}
socket_path=${2:-}
[[ -n $socket_path ]] || exit 0
tmux_command=(tmux -S "$socket_path")
pane_field_separator=$'\x1f'
pane_format="#{pane_id}${pane_field_separator}#{pane_current_command}${pane_field_separator}#{pane_title}${pane_field_separator}#{@agent-status}"

get_pane_status() {
	"${tmux_command[@]}" show-option -pqv -t "$1" @agent-status 2>/dev/null
}

set_pane_status() {
	"${tmux_command[@]}" set-option -p -t "$1" @agent-status "$2" 2>/dev/null
}

clear_pane_status() {
	local pane_id=$1
	if [[ $(get_pane_status "$pane_id") == done ]]; then
		"${tmux_command[@]}" set-option -pu -t "$pane_id" @agent-status 2>/dev/null || true
	fi
}

clear_window_status() {
	local pane_id
	while IFS= read -r pane_id; do
		[[ -n $pane_id ]] && clear_pane_status "$pane_id"
	done < <("${tmux_command[@]}" list-panes -t "$1" -F '#{pane_id}' 2>/dev/null)
}

detect_pane_busy() {
	local pane_id=$1 pane_command=$2 pane_title=$3 pane_content
	local working_pattern='(^|[[:space:]])Working(\.\.\.)?([[:space:]]|$)'
	local interrupt_pattern='[Ee][Ss][Cc]([Aa][Pp][Ee])?[[:space:]]+[Tt][Oo][[:space:]]+[Ii][Nn][Tt][Ee][Rr][Rr][Uu][Pp][Tt]'

	case "$pane_title" in
		⠋* | ⠙* | ⠹* | ⠸* | ⠼* | ⠴* | ⠦* | ⠧* | ⠇* | ⠏*) return 0 ;;
	esac

	case "$pane_command" in
		codex | cursor-agent | node | pi | claude) ;;
		*) return 1 ;;
	esac

	pane_content=$("${tmux_command[@]}" capture-pane -p -t "$pane_id" 2>/dev/null) || return 2

	case "$pane_command" in
		cursor-agent | pi)
			[[ $pane_content =~ $working_pattern ]] && return 0
			;;
	esac

	[[ $pane_content =~ $interrupt_pattern ]]
}

pane_is_visible() {
	local pane_id=$1 client_panes=$2 active_pane
	while IFS= read -r active_pane; do
		[[ $active_pane == "$pane_id" ]] && return 0
	done <<< "$client_panes"
	return 1
}

print_pane_status() {
	case "$1" in
		busy) printf '1' ;;
		done) printf '2' ;;
		*) printf '0' ;;
	esac
}

check_pane_status() {
	local pane_id=$1 pane_command=$2 pane_title=$3 previous_status=$4 client_panes=$5
	local detection_result
	checked_pane_status=$previous_status

	detect_pane_busy "$pane_id" "$pane_command" "$pane_title"
	detection_result=$?

	if [[ $detection_result == 0 ]]; then
		[[ $previous_status == busy ]] || set_pane_status "$pane_id" busy
		checked_pane_status=busy
		return
	fi

	if [[ $detection_result == 2 ]]; then
		return
	fi

	if [[ $previous_status == busy ]]; then
		if pane_is_visible "$pane_id" "$client_panes"; then
			"${tmux_command[@]}" set-option -pu -t "$pane_id" @agent-status 2>/dev/null || true
			checked_pane_status=
		else
			set_pane_status "$pane_id" done
			checked_pane_status=done
		fi
	fi
}

scan_all_panes() {
	local pane_rows client_panes pane_id pane_command pane_title previous_status
	local any_busy=0

	pane_rows=$("${tmux_command[@]}" list-panes -a -F "$pane_format" 2>/dev/null) || return 2
	client_panes=$("${tmux_command[@]}" list-clients -F '#{pane_id}' 2>/dev/null)

	while IFS="$pane_field_separator" read -r pane_id pane_command pane_title previous_status; do
		[[ -n $pane_id ]] || continue
		check_pane_status "$pane_id" "$pane_command" "$pane_title" "$previous_status" "$client_panes"
		[[ $checked_pane_status == busy ]] && any_busy=1
	done <<< "$pane_rows"

	[[ $any_busy == 1 && -n $client_panes ]]
}

run_ticker() {
	local existing_pid current_pid frame scan_pid scan_result
	local spinner_active=0 frame_index=0 ticks_until_scan=0
	local frames=(⠹ ⢸ ⣰ ⣤ ⣆ ⡇ ⠏ ⠛)

	existing_pid=$("${tmux_command[@]}" show-option -gqv @agent-spinner-ticker-pid 2>/dev/null)
	if [[ $existing_pid =~ ^[0-9]+$ ]] && kill -0 "$existing_pid" 2>/dev/null; then
		exit 0
	fi

	"${tmux_command[@]}" set-option -g @agent-spinner-ticker-pid "$$" 2>/dev/null || exit 0

	cleanup() {
		if [[ -n $scan_pid ]]; then
			kill "$scan_pid" 2>/dev/null || true
			wait "$scan_pid" 2>/dev/null || true
		fi

		current_pid=$("${tmux_command[@]}" show-option -gqv @agent-spinner-ticker-pid 2>/dev/null)
		if [[ $current_pid == "$$" ]]; then
			"${tmux_command[@]}" set-option -gu @agent-spinner-ticker-pid 2>/dev/null || true
			"${tmux_command[@]}" set-option -gu @agent-spinner-frame 2>/dev/null || true
		fi
	}
	trap cleanup EXIT
	trap 'exit 0' HUP INT TERM

	while :; do
		if [[ $spinner_active == 0 ]]; then
			scan_all_panes
			scan_result=$?
			case "$scan_result" in
				0)
					spinner_active=1
					ticks_until_scan=8
					;;
				1)
					sleep 1
					continue
					;;
				*) exit 0 ;;
			esac
		fi

		if [[ -n $scan_pid ]] && ! kill -0 "$scan_pid" 2>/dev/null; then
			wait "$scan_pid"
			scan_result=$?
			scan_pid=
			case "$scan_result" in
				0) ;;
				1) spinner_active=0 ;;
				*) exit 0 ;;
			esac
		fi

		if [[ $spinner_active == 0 ]]; then
			sleep 1
			continue
		fi

		if [[ $ticks_until_scan == 0 && -z $scan_pid ]]; then
			scan_all_panes &
			scan_pid=$!
			ticks_until_scan=8
		fi

		frame=${frames[$frame_index]}
		"${tmux_command[@]}" set-option -g @agent-spinner-frame "$frame" 2>/dev/null || exit 0
		frame_index=$(((frame_index + 1) % ${#frames[@]}))
		sleep 0.125
		if [[ $ticks_until_scan -gt 0 ]]; then
			ticks_until_scan=$((ticks_until_scan - 1))
		fi
	done
}

case "$mode" in
	tick)
		run_ticker
		;;
	check)
		pane_id=${3:-}
		if [[ $pane_id =~ ^%[0-9]+$ ]]; then
			pane_details=$("${tmux_command[@]}" display-message -p -t "$pane_id" "$pane_format" 2>/dev/null) || exit 0
			client_panes=$("${tmux_command[@]}" list-clients -F '#{pane_id}' 2>/dev/null)
			IFS="$pane_field_separator" read -r pane_id pane_command pane_title previous_status <<< "$pane_details"
			check_pane_status "$pane_id" "$pane_command" "$pane_title" "$previous_status" "$client_panes"
			print_pane_status "$checked_pane_status"
		fi
		;;
	clear-pane)
		pane_id=${3:-}
		[[ $pane_id =~ ^%[0-9]+$ ]] && clear_pane_status "$pane_id"
		;;
	clear-window)
		window_id=${3:-}
		[[ $window_id =~ ^@[0-9]+$ ]] && clear_window_status "$window_id"
		;;
esac
